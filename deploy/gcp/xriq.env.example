# XRIQ staging-devnet service configuration.
# On the VM this lives at /etc/xriq/xriq.env (mode 600) and is written by
# vm-bootstrap.sh with the real DB password fetched from Secret Manager.
# This example contains NO real secret. Never commit a filled-in xriq.env.

# Artifact Registry image (region-docker.pkg.dev/PROJECT/REPO/xriq:TAG).
XRIQ_IMAGE=northamerica-northeast2-docker.pkg.dev/xriq-project-dev/xriq-staging-devnet-containers/xriq:latest

XRIQ_ENVIRONMENT=staging-devnet

# Deterministic genesis input: must be identical for the node, API, and indexer.
XRIQ_ALICE_BALANCE=100000000

XRIQ_API_BIND=0.0.0.0:8090

# Accepted mutations for staging (explicit and auditable). Set empty for a
# strictly read-only API.
XRIQ_API_MUTATION_FLAGS="--enable-local-wallet-send true --enable-local-wallet-submit-signed true --enable-local-block-production true"

# Cloud SQL private connection for the indexer AND (when set) the API read model.
# The password is fetched from Secret Manager by vm-bootstrap.sh; this
# placeholder is not a real secret. When this is set, xriq-api-run.sh serves the
# Postgres read model from it via --postgres-database-url-env XRIQ_POSTGRES_URL.
# Set XRIQ_API_POSTGRES_FLAGS to empty to keep the API strictly file-backed.
XRIQ_POSTGRES_URL=postgresql://xriqpgadmin:REPLACE_FROM_SECRET_MANAGER@10.103.0.3:5432/xriq

# --- Multi-node testnet (TEST-ONLY, no monetary value) ---
# Used by xriq-testnet-node-run.sh (seed + followers) and xriq-peer-sync-run.sh
# (followers). The testnet runs the test-only signature scheme; production crypto
# is a separate migration. Nodes are VPC-internal only (firewall by network tag).
XRIQ_TESTNET_CHAIN_FILE=/data/testnet/chain.bin
XRIQ_TESTNET_BIND=0.0.0.0:8899
# Seed extras (optional): a stable node id and/or an advertised peers file.
# XRIQ_TESTNET_NODE_FLAGS="--node-seed my-seed-id --peers-file /data/testnet/peers"
XRIQ_TESTNET_NODE_FLAGS=
# Followers: the seed's internal peer URL (from the terraform testnet_seed_internal_ip output).
XRIQ_TESTNET_SEED_URL=http://SEED_INTERNAL_IP:8899
XRIQ_TESTNET_SYNC_MAX_ROUNDS=64
