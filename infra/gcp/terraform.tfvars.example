# Example variables for the XRIQ GCP staging-devnet.
# Copy to terraform.tfvars (gitignored) and edit. Contains NO secrets. The
# Cloud SQL admin password is supplied separately at apply time via
# TF_VAR_postgres_admin_password (e.g. read from Secret Manager), never here.
# project_id and billing_account are identifiers, not secrets.

project_id  = "xriq-private-dev"
project     = "xriq"
environment = "staging-devnet"
region      = "northamerica-northeast2"
zone        = "northamerica-northeast2-a"

# 3-8 lowercase alphanumeric chars; makes the Cloud Storage bucket name unique.
name_suffix = "dev01"

# Cloud Billing account id (XXXXXX-XXXXXX-XXXXXX) and budget settings.
billing_account                 = "000000-000000-000000"
monthly_budget_amount           = 150
budget_alert_threshold_percents = [80, 100]
budget_notification_email       = "xriq@kani.network"

postgres_tier       = "db-f1-micro"
postgres_admin_user = "xriqpgadmin"

vm_machine_type = "e2-small"
ssh_user        = "xriqop"
# Your SSH PUBLIC key (not a secret). The private key stays on your machine.
ssh_public_key = "ssh-ed25519 AAAA...replace-with-your-public-key... operator@xriq"
# Optional: your IP in CIDR form to open inbound SSH, e.g. "203.0.113.4/32".
# operator_allowed_cidr = "203.0.113.4/32"

labels = {
  project     = "xriq"
  environment = "staging-devnet"
  managed_by  = "terraform"
  scope       = "private-staging-no-public-financial-claims"
}
