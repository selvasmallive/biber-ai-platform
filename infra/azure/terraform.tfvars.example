# Example variables for the XRIQ Azure staging-devnet.
# Copy to terraform.tfvars (gitignored) and edit. Contains NO secrets and NO
# subscription/tenant identifiers; those come from the environment / az login at
# apply time. The PostgreSQL admin password is supplied separately at apply time
# via TF_VAR_postgres_admin_password (e.g. read from Key Vault), never here.

project     = "xriq"
environment = "staging-devnet"
location    = "eastus"

# 3-8 lowercase alphanumeric chars; makes globally-unique names unique
# (storage account, Key Vault, container registry, PostgreSQL server).
name_suffix = "dev01"

monthly_budget_amount           = 150
budget_alert_threshold_percents = [80, 100]
budget_contact_emails           = ["selva@kani.network"]
# Set to the first of the current month at apply time.
budget_start_date = "2026-06-01T00:00:00Z"

postgres_sku_name   = "B_Standard_B1ms"
postgres_storage_mb = 32768
postgres_admin_login = "xriqpgadmin"

vm_size        = "Standard_B2s"
admin_username = "xriqop"
# Your SSH PUBLIC key (not a secret). The private key stays on your machine.
ssh_public_key = "ssh-ed25519 AAAA...replace-with-your-public-key... operator@xriq"
# Optional: your IP in CIDR form to open inbound SSH, e.g. "203.0.113.4/32".
# Leave unset to keep SSH closed at the network security group.
# operator_allowed_cidr = "203.0.113.4/32"

tags = {
  project     = "xriq"
  environment = "staging-devnet"
  managed_by  = "terraform"
  scope       = "private-staging-no-public-financial-claims"
}
