{
  "name": "@xriq/explorer-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Local private-devnet XRIQ explorer UI.",
  "type": "module",
  "scripts": {
    "check": "node scripts/check-static.mjs && node scripts/check-wallet-submit-accepted-contract.mjs && node scripts/check-wallet-send-accepted-contract.mjs && node scripts/check-wallet-send-ui-control.mjs && node scripts/check-block-production-ui-control.mjs",
    "check:wallet-submit": "node scripts/check-wallet-submit-accepted-contract.mjs",
    "check:wallet-send": "node scripts/check-wallet-send-accepted-contract.mjs",
    "check:wallet-send-ui-live": "node scripts/check-wallet-send-ui-live.mjs",
    "check:wallet-send-refresh-live": "node scripts/check-wallet-send-refresh-live.mjs",
    "check:block-production-ui-live": "node scripts/check-block-production-ui-live.mjs",
    "check:block-production-admin-refresh-live": "node scripts/check-block-production-admin-refresh-live.mjs",
    "check:block-production-no-pending-live": "node scripts/check-block-production-no-pending-live.mjs",
    "check:postgres-ui": "node scripts/check-postgres-ui-state.mjs",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
