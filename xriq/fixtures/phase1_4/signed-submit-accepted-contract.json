{
  "environment": "private-devnet",
  "network": "xriq-devnet",
  "endpoint": "POST /api/v1/wallet/transfers/submit-signed",
  "contract": "phase1-4-signed-submit-accepted-v1",
  "status": "contract-inventory-only",
  "implementation_status": "not-implemented",
  "default_outcome": "refused",
  "accepted_outcome": "pending-transaction-after-explicit-local-flag-and-verification",
  "mutation": "none-until-explicit-local-enable-and-valid-test-signature",
  "warning": "local-private-devnet-test-signature-only",
  "default_refusal": {
    "fixture": "signed-submit-disabled.json",
    "code": "signed_submit_disabled",
    "mutation": "none",
    "status": "disabled"
  },
  "required_enablement": {
    "mode": "local-private-devnet",
    "explicit_flag": "--enable-local-wallet-submit-signed",
    "audit_event_required": true,
    "test_identity_only": true
  },
  "request_schema": {
    "required_fields": [
      "local_request_id",
      "pending_file",
      "chain_file",
      "signed_transfer_envelope"
    ],
    "envelope_required_fields": [
      "format_version",
      "transaction",
      "hashes",
      "signature_envelope"
    ],
    "forbidden_fields": [
      "private_key",
      "seed_phrase",
      "mnemonic",
      "secret_key",
      "raw_signature",
      "custody_account",
      "public_network_endpoint",
      "dex_route"
    ],
    "guards": [
      "local_request_id is required for audit correlation",
      "pending_file must be a local private-devnet pending file",
      "chain_file must be a local private-devnet chain file",
      "format_version must be xriq-local-signed-transfer-envelope-v1",
      "chain_id must equal xriq-devnet",
      "sender must be a configured local test identity",
      "signature algorithm must be test-only for Phase 1.4",
      "transaction_signing_hash must match canonical transaction_signing_hash",
      "transaction_hash must match canonical transaction_hash",
      "signature must verify with TestOnlySignatureVerifier",
      "nonce, fee, balance, expiry, and duplicate pending state must pass before mutation"
    ]
  },
  "accepted_response_schema": {
    "required_fields": [
      "environment",
      "network",
      "endpoint",
      "code",
      "status",
      "mutation",
      "warning",
      "transaction",
      "verification",
      "pending_state",
      "chain_state",
      "audit_event_recorded",
      "audit_event"
    ],
    "status": "pending",
    "mutation": "pending_state_only",
    "verification_fields": [
      "signature_algorithm",
      "transaction_signing_hash",
      "transaction_hash",
      "verifier",
      "verified"
    ],
    "pending_state_fields": [
      "before_count",
      "after_count",
      "added_tx_hash",
      "pending_file"
    ],
    "chain_state_fields": [
      "current_height",
      "latest_block_hash",
      "chain_file",
      "chain_unchanged"
    ]
  },
