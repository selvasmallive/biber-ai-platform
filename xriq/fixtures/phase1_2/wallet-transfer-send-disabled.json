{
  "environment": "private-devnet",
  "network": "xriq-devnet",
  "endpoint": "POST /api/v1/wallet/transfers/send",
  "enabled": false,
  "mutation": "none",
  "status": "disabled",
  "code": "wallet_send_disabled",
  "error": "wallet transfer send is disabled by default in Phase 1.2 preflight mode",
