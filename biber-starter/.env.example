# BIBER environment configuration

BIBER_ENV=dev
BIBER_API_HOST=0.0.0.0
BIBER_API_PORT=8000

# Change these before production
BIBER_ADMIN_USERNAME=biber_admin
BIBER_ADMIN_PASSWORD=ChangeMeImmediately!123

# Demo API key. Replace with generated keys later.
BIBER_DEMO_API_KEY=dev-api-key-change-me

# Demo passcodes
BIBER_PASSCODE_FULL_GPU=BIBER_FULL_GPU_DEMO
BIBER_PASSCODE_20_GPU=BIBER_20_GPU_DEMO
BIBER_PASSCODE_QUEUE_PRIORITY=BIBER_QUEUE_PRIORITY_DEMO

# Database
MYSQL_ROOT_PASSWORD=biber_root_change_me
MYSQL_DATABASE=biber
MYSQL_USER=biber_user
MYSQL_PASSWORD=biber_password_change_me
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Models
BIBER_DEFAULT_MODEL=biber-dev-core
BIBER_MODEL_DIR=/models
